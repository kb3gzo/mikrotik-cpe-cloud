# CPE Cloud telemetry -- classic /interface wireless path
#
# Deliverable #8 Chunks A+B: device identity, system metrics, ethernet[],
# wireless_interfaces[]. Chunk C will append clients[]. Server-side schema
# uses extra="allow" on nested models so a partial payload from any chunk
# still validates -- safe to roll out either side first.
#
# Context variables available from the parent provision.rsc.j2 render:
#   {{ telemetry_token }}   -- raw bearer token (embedded below)
#   {{ telemetry_url }}     -- POST target
#   {{ router.identity }}   -- used only as a log breadcrumb

:local telemetryUrl   "{{ telemetry_url }}"
:local telemetryToken "{{ telemetry_token }}"

# --- Static-ish device identity --------------------------------------------
# Board + serial don't change across reboots but we re-emit on every push so
# the server can UPSERT cheaply (useful after a firmware upgrade changes
# ros-version, or if identity was edited on-device).
:local identity [/system identity get name]
:local serial   ""
:do { :set serial  [/system routerboard get serial-number] } on-error={}
:local board    ""
:do { :set board   [/system routerboard get model] } on-error={}
:local mac      ""
:do { :set mac     [/interface ethernet get [find name=ether1] mac-address] } on-error={}
:local rosVer   [/system resource get version]

# --- System metrics --------------------------------------------------------
:local uptime   [/system resource get uptime]
:local cpuLoad  [/system resource get cpu-load]
:local freeMem  [/system resource get free-memory]
:local totalMem [/system resource get total-memory]

# /system health is device-specific: hAP ac2 has no probes, hAP ax3 has
# temperature + voltage. Emit only the sensors that actually exist --
# server-side these fields are Optional and missing != zero.
:local hasTemp false
:local temp    0
:do {
    :local tid [/system health find name=temperature]
    :if ([:len $tid] > 0) do={
        :set temp    [/system health get $tid value]
        :set hasTemp true
    }
} on-error={}

:local hasVolt false
:local volt    0
:do {
    :local vid [/system health find name=voltage]
    :if ([:len $vid] > 0) do={
        :set volt    [/system health get $vid value]
        :set hasVolt true
    }
} on-error={}

# --- Build JSON payload ----------------------------------------------------
# String concatenation because RouterOS has no real JSON serializer.
:local payload  "{"
:set payload ($payload . "\"schema_version\":1,")
:set payload ($payload . "\"identity\":\"$identity\",")
:set payload ($payload . "\"serial\":\"$serial\",")
:set payload ($payload . "\"mac\":\"$mac\",")
:set payload ($payload . "\"board\":\"$board\",")
:set payload ($payload . "\"ros_version\":\"$rosVer\",")
:set payload ($payload . "\"wifi_stack\":\"wireless\",")

:set payload ($payload . "\"system\":{")
:set payload ($payload . "\"uptime\":\"$uptime\",")
:set payload ($payload . "\"cpu_load_pct\":$cpuLoad,")
:set payload ($payload . "\"free_memory_bytes\":$freeMem,")
:set payload ($payload . "\"total_memory_bytes\":$totalMem")
:if ($hasTemp) do={ :set payload ($payload . ",\"temperature_c\":$temp") }
:if ($hasVolt) do={ :set payload ($payload . ",\"voltage_v\":$volt") }
:set payload ($payload . "}")

# --- Chunk B: ethernet interfaces ------------------------------------------
# /interface ethernet find returns all ether* ports including disabled ones.
# rx-byte/tx-byte/rx-packet/tx-packet come off the parent /interface get,
# not the ethernet-specific subtree, so we use $e as the index there too.
:set payload ($payload . ",\"ethernet\":[")
:local first true
:foreach e in=[/interface ethernet find] do={
    :if ($first = false) do={ :set payload ($payload . ",") }
    :set first false
    :local ename    [/interface ethernet get $e name]
    :local erunning [/interface ethernet get $e running]
    :local erxb     [/interface get $e rx-byte]
    :local etxb     [/interface get $e tx-byte]
    :local erxp     [/interface get $e rx-packet]
    :local etxp     [/interface get $e tx-packet]
    :set payload ($payload . "{\"name\":\"$ename\",\"running\":$erunning,")
    :set payload ($payload . "\"rx_bytes\":$erxb,\"tx_bytes\":$etxb,")
    :set payload ($payload . "\"rx_packets\":$erxp,\"tx_packets\":$etxp}")
}
:set payload ($payload . "]")

# --- Chunk B: wireless interfaces (classic stack) --------------------------
# Counters via /interface get (same pattern as ethernet). Metadata via
# /interface wireless get -- ssid/frequency/tx-power can be empty depending
# on radio state, so we emit them conditionally to avoid "field":, garbage.
:set payload ($payload . ",\"wireless_interfaces\":[")
:set first true
:foreach w in=[/interface wireless find] do={
    :if ($first = false) do={ :set payload ($payload . ",") }
    :set first false
    :local wname  [/interface wireless get $w name]
    :local wssid  ""
    :local wband  ""
    :local wfreq  ""
    :local wcw    ""
    :local wtxp   ""
    :local wmode  ""
    :local wdis   true
    :do { :set wssid [/interface wireless get $w ssid] } on-error={}
    :do { :set wband [/interface wireless get $w band] } on-error={}
    :do { :set wfreq [/interface wireless get $w frequency] } on-error={}
    :do { :set wcw   [/interface wireless get $w channel-width] } on-error={}
    :do { :set wtxp  [/interface wireless get $w tx-power] } on-error={}
    :do { :set wmode [/interface wireless get $w mode] } on-error={}
    :do { :set wdis  [/interface wireless get $w disabled] } on-error={}
    # frequency can be "auto" on some configs -- only emit if it parses as
    # an integer, otherwise we'd produce invalid JSON like "frequency":auto
    :local wfreqNum 0
    :local wfreqOk  false
    :do { :set wfreqNum [:tonum $wfreq]; :set wfreqOk true } on-error={}
    :local wrxb     [/interface get $w rx-byte]
    :local wtxb     [/interface get $w tx-byte]
    :local wrxp     [/interface get $w rx-packet]
    :local wtxp_pkt [/interface get $w tx-packet]
    :set payload ($payload . "{\"name\":\"$wname\",\"disabled\":$wdis,")
    :set payload ($payload . "\"rx_bytes\":$wrxb,\"tx_bytes\":$wtxb,")
    :set payload ($payload . "\"rx_packets\":$wrxp,\"tx_packets\":$wtxp_pkt")
    :if ([:len $wssid] > 0) do={ :set payload ($payload . ",\"ssid\":\"$wssid\"") }
    :if ([:len $wband] > 0) do={ :set payload ($payload . ",\"band\":\"$wband\"") }
    :if ($wfreqOk)         do={ :set payload ($payload . ",\"frequency\":$wfreqNum") }
    :if ([:len $wcw]   > 0) do={ :set payload ($payload . ",\"channel_width\":\"$wcw\"") }
    :if ([:len $wtxp]  > 0) do={ :set payload ($payload . ",\"tx_power\":\"$wtxp\"") }
    :if ([:len $wmode] > 0) do={ :set payload ($payload . ",\"mode\":\"$wmode\"") }
    :set payload ($payload . "}")
}
:set payload ($payload . "]")

# Chunk C will append: ,"clients":[...]

:set payload ($payload . "}")

# --- POST to server --------------------------------------------------------
:do {
    /tool fetch url=$telemetryUrl \
        http-method=post \
        http-header-field=("Content-Type: application/json,Authorization: Bearer " . $telemetryToken) \
        http-data=$payload \
        mode=https \
        output=none
} on-error={
    :log warning "cpe-cloud: telemetry push failed"
}
