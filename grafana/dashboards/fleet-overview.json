{
  "__inputs": [
    {
      "name": "DS_INFLUXDB_CPE_TELEMETRY",
      "label": "InfluxDB - CPE Telemetry",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    },
    {
      "name": "DS_POSTGRES_CPE_CLOUD",
      "label": "Postgres - CPE Cloud",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0"},
    {"type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Routers Enrolled",
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM routers WHERE status IN ('active','pending')"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reporting (last 15m)",
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM routers WHERE status = 'active' AND last_seen_at > NOW() - INTERVAL '15 minutes'"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Offline (active, >15m silent)",
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM routers WHERE status = 'active' AND (last_seen_at IS NULL OR last_seen_at < NOW() - INTERVAL '15 minutes')"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pending Approval",
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "orange", "value": 1}
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*)::int AS value FROM routers WHERE status = 'pending'"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Load % (per router)",
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
          "query": "from(bucket: \"cpe-system-raw\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"cpu_load_pct\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"router_id\", \"model\"])\n  |> group(columns: [\"router_id\", \"model\"])"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Used % (per router)",
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
          "query": "from(bucket: \"cpe-system-raw\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"system\" and (r._field == \"free_memory_bytes\" or r._field == \"total_memory_bytes\"))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> pivot(rowKey: [\"_time\", \"router_id\", \"model\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({\n      _time: r._time,\n      router_id: r.router_id,\n      model: r.model,\n      _value: 100.0 * float(v: r.total_memory_bytes - r.free_memory_bytes) / float(v: r.total_memory_bytes)\n    }))\n  |> group(columns: [\"router_id\", \"model\"])"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Uptime (hours)",
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "h",
          "min": 0
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
          "query": "from(bucket: \"cpe-system-raw\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"uptime_sec\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> map(fn: (r) => ({r with _value: float(v: r._value) / 3600.0}))\n  |> keep(columns: [\"_time\", \"_value\", \"router_id\", \"model\"])\n  |> group(columns: [\"router_id\", \"model\"])"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Temperature (C) -- ax2/ax3 only",
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "celsius"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB_CPE_TELEMETRY}"},
          "query": "from(bucket: \"cpe-system-raw\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"temperature_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"router_id\", \"model\"])\n  |> group(columns: [\"router_id\", \"model\"])"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Router Inventory",
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 21},
      "options": {
        "showHeader": true,
        "footer": {"show": false, "reducer": ["sum"], "fields": ""}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Min Since Seen"},
            "properties": [
              {"id": "unit", "value": "m"},
              {"id": "decimals", "value": 1},
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-background", "mode": "gradient"}
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 15},
                    {"color": "red", "value": 60}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"active":        {"color": "green",  "index": 0}}},
                  {"type": "value", "options": {"pending":       {"color": "blue",   "index": 1}}},
                  {"type": "value", "options": {"quarantined":   {"color": "orange", "index": 2}}},
                  {"type": "value", "options": {"decommissioned":{"color": "red",    "index": 3}}}
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-text"}
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES_CPE_CLOUD}"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  id AS \"ID\",\n  identity AS \"Identity\",\n  model AS \"Model\",\n  wifi_stack AS \"Wi-Fi Stack\",\n  ros_version AS \"ROS\",\n  status AS \"Status\",\n  last_seen_at AS \"Last Seen\",\n  ROUND(EXTRACT(EPOCH FROM (NOW() - last_seen_at)) / 60.0, 1) AS \"Min Since Seen\"\nFROM routers\nORDER BY last_seen_at DESC NULLS LAST"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cpe-cloud", "fleet"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "CPE Cloud -- Fleet Overview",
  "uid": "cpe-fleet-overview",
  "version": 1,
  "weekStart": ""
}
