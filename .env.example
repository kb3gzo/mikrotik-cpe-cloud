# ---------------------------------------------------------------------------
# Mikrotik CPE Cloud — environment template
# Copy to `.env` and fill in real values. The .env file is NOT checked in.
# ---------------------------------------------------------------------------

# Postgres — asyncpg-compatible DSN (psycopg3 async driver)
DATABASE_URL=postgresql+psycopg://cpecloud:CHANGE_ME@127.0.0.1:5432/cpecloud

# InfluxDB 2.x
INFLUX_URL=http://127.0.0.1:8086
INFLUX_ORG=bradford
INFLUX_BUCKET=cpe-cloud
INFLUX_TOKEN=CHANGE_ME

# Public-facing base URL — used in rendered RouterOS scripts
SERVER_FQDN=mcc.bradfordbroadband.com
ENROLLMENT_URL=https://mcc.bradfordbroadband.com/api/v1/auto-enroll

# WireGuard overlay
WG_INTERFACE=wg0
WG_OVERLAY_CIDR=10.100.0.0/22
WG_SERVER_IP=10.100.0.1
WG_SERVER_PUBLIC_KEY=CHANGE_ME
WG_SERVER_ENDPOINT=mcc.bradfordbroadband.com:51820
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_SYNC_HELPER=/usr/local/sbin/cpe-cloud-wg-sync

# Provisioning secret — plaintext lives here (systemd LoadCredential in prod).
# Postgres only stores the hash. Set to the *current* secret; rotate by
# issuing a new one via `python -m app.cli provisioning-secret rotate`.
PROVISIONING_SECRET_CURRENT=CHANGE_ME

# App
APP_LOG_LEVEL=INFO
APP_ENV=dev
